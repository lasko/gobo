<?xml version="1.0" encoding="utf-8"?>
<!-- Keep auth tokens off cloud backup and device-to-device transfer. -->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="sharedpref" path="gobo_secure_prefs.xml" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="gobo_secure_prefs.xml" />
    </device-transfer>
</data-extraction-rules>
